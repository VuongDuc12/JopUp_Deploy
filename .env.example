# ─── Copy file này thành .env và điền giá trị thật ───────────────────────────
# cp .env.example .env

# ─── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=ducdev04.pro.vn
FE_BASE_URL=https://ducdev04.pro.vn
BE_BASE_URL=https://api.ducdev04.pro.vn

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=jopup_db
POSTGRES_USER=jopup_user
POSTGRES_PASSWORD=jopup_password

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Tạo key ngẫu nhiên: openssl rand -base64 32
JWT_KEY=Lt6JvZbU15auGycWskmfIRXcA4EjBScU
JWT_EXPIRED_HOURS=168
JWT_ISSUER=Jopup
JWT_AUDIENCE=Client

# ─── SMTP (Gmail App Password) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ─── Certbot (Let's Encrypt) ───────────────────────────────────────────────────
CERTBOT_EMAIL=your-email@gmail.com
